# =============================================
# Teknoel - Production Environment Variables
# =============================================
# Bu dosyayı kopyalayıp .env adıyla kaydedin:
#   cp .env.production.example .env
# Sonra tüm değerleri doldurun.

# --- Veritabanı ---
# SQLite (VPS):
DATABASE_URL="file:./teknoel.db"
# PostgreSQL (Vercel/Railway/Supabase önerilir):
# DATABASE_URL="postgresql://user:password@host:5432/teknoel"

# --- NextAuth ---
# Güçlü rastgele secret (aşağıdaki komutu çalıştırarak üretin):
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
NEXTAUTH_SECRET="BURAYA_RASTGELE_64_BYTE_HEX_GIRIN"

# Sitenizin tam URL'si (sonunda / olmadan)
NEXTAUTH_URL="https://teknoel.com"

# --- Uygulama ---
# Standalone Docker build için (isteğe bağlı)
# BUILD_STANDALONE=1

# --- (Gelecek) Cloudinary - Resim Yükleme ---
# Şu an local /public/uploads/ kullanılıyor.
# Production'da Cloudinary önerilir:
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
